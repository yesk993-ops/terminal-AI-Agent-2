#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ $# -eq 0 ]; then
    echo "Usage: tell <your request>"
    echo ""
    echo "Examples:"
    echo "  tell \"create a flask app\""
    echo "  tell \"check disk usage\""
    echo "  tell \"update my system\""
    exit 1
fi

if [ -z "$NVIDIA_API_KEY" ]; then
    echo "Error: NVIDIA_API_KEY is not set."
    echo "Get a key: https://build.nvidia.com/explore"
    echo "Then: export NVIDIA_API_KEY=\"nvapi-...\""
    exit 1
fi

# Use venv if it exists
if [ -f "$SCRIPT_DIR/.venv/bin/python3" ]; then
    PYTHON="$SCRIPT_DIR/.venv/bin/python3"
else
    for cmd in python3 python; do
        if command -v "$cmd" &>/dev/null; then
            PYTHON="$cmd"
            break
        fi
    done
fi

if [ -z "$PYTHON" ]; then
    echo "Error: Python not found. Run 'bash install.sh' first."
    exit 1
fi

exec "$PYTHON" "$SCRIPT_DIR/agent.py" --inline "$@"
